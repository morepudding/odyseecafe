OPEN_ROUTER_API_KEY=sk-or-v1-your-key-here

# Modèle à utiliser (changeable sans toucher au code)
# Exemples : openai/gpt-4o | anthropic/claude-3.5-sonnet | mistralai/mistral-large
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Nom affiché dans les stats OpenRouter
OPENROUTER_APP_NAME=historycafe-napoleon

# ─── Twitter / X ─────────────────────────────────────────────────────────────
# 1. Crée une app sur https://developer.twitter.com/en/portal/dashboard
# 2. Active "Read and Write" permissions
# 3. Génère les tokens pour le compte @Napoleon_IA (OAuth 1.0a)

# Pour LIRE les tweets (Bearer Token de l'app Developer)
TWITTER_BEARER_TOKEN=your-bearer-token

# Pour POSTER depuis le compte @Napoleon_IA (OAuth 1.0a User Access)
TWITTER_API_KEY=your-api-key
TWITTER_API_SECRET=your-api-secret
TWITTER_ACCESS_TOKEN=your-access-token
TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
