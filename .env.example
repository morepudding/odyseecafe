OPEN_ROUTER_API_KEY=sk-or-v1-your-key-here

# Chat model used through OpenRouter.
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_APP_NAME=odyseecafe-napoleon

# Embedding model used for Supabase pgvector ingestion and retrieval.
OPENROUTER_EMBED_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free

# Production RAG backend. On Vercel, Supabase is enforced by default.
RAG_BACKEND=supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Required only for local ingestion/admin writes. Never expose this client-side.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
